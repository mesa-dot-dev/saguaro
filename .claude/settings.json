{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "sag hook pre-tool",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sag hook run",
            "timeout": 120,
            "statusMessage": "Saguaro: reviewing changes..."
          }
        ]
      }
    ]
  }
}
