class ${FORMULA_CLASS_NAME} < Formula
  desc "Mesa code review CLI"
  homepage "https://mesa.dev"
  url "${URL}"
  sha256 "${SHA256}"
  license "Apache-2.0"
  version "${VERSION}"

  def install
    if Hardware::CPU.arm?
      bin.install "mesa-darwin-arm64" => "mesa"
    else
      bin.install "mesa-darwin-x64" => "mesa"
    end
  end

  test do
    assert_match "mesa", shell_output("#{bin}/mesa --help")
  end
end
