{
  "name": "@mesa/code-review",
  "version": "0.2.17",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "mesa": "./dist/cli/bin/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:binary": "bash scripts/build-binary.sh",
    "prepack": "bun run build",
    "review": "bun run build && node dist/cli/bin/index.js review",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.38",
    "@ai-sdk/google": "^3.0.22",
    "@ai-sdk/openai": "^3.0.26",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@swc/core": "^1.15.11",
    "ai": "^6.0.75",
    "boxen": "^5.1.2",
    "chalk": "^4.1.2",
    "dotenv": "^17.2.4",
    "js-yaml": "^4.1.1",
    "minimatch": "^10.1.2",
    "oxc-resolver": "^11.17.0",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "0.25.10",
    "yargs": "^18.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "1.3.9",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.2.0",
    "@types/yargs": "^17.0.35",
    "bun-types": "1.3.9",
    "typescript": "^5.9.3"
  }
