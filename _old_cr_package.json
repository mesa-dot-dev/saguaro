{
  "name": "@mesa/code-review",
  "version": "0.0.3",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "mesa": "./dist/cli/bin/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "bun run build",
    "link": "bun install && bun run build && chmod +x dist/cli/bin/index.js && npm link",
    "relink": "rm -rf dist && bun run link",
    "review": "bun run build && node dist/cli/bin/index.js review",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.38",
    "@ai-sdk/google": "^3.0.22",
    "@ai-sdk/openai": "^3.0.26",
    "@swc/core": "^1.15.11",
    "@swc/wasm": "^1.15.11",
    "ai": "^6.0.75",
    "boxen": "^5.1.2",
    "chalk": "^4.1.2",
    "dotenv": "^17.2.4",
    "figlet": "^1.10.0",
    "js-yaml": "^4.1.1",
    "minimatch": "^10.1.2",
    "oxc-resolver": "^11.17.0",
    "yargs": "^18.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/figlet": "^1.7.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.2.0",
    "@types/yargs": "^17.0.35",
    "bun-types": "latest",
    "typescript": "^5.9.3"
  }
}
